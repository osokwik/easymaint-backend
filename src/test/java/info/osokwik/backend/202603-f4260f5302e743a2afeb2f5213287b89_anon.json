    "transcription": {
      "language": "en",
      "duration": 45.0,
      "text": "Riverside Mechanics, this is Tom. Hi, my name is Kevin. A coworker recommended you. I need new tires for my 2021 Subaru Crosstrek. What are you running now? I think they're 225/60R17. Let me check what we have. We've got Michelin Defenders at $165 each or Continental TrueContact at $140 each. Both installed and balanced. I'll go with the Continentals. That's $560 plus tax for all four. When can I come in? How about Wednesday at 11? Wednesday at 11 works. Thanks Tom. See you then, Kevin.",
      "summary": "## Call Summary\n\nNew customer Kevin (referral) needs tires for 2021 Subaru Crosstrek. Chose Continental TrueContact at $140/each = $560 + tax. Appointment Wednesday 11 AM.\n",
      "segments": [
        {
          "text": "Riverside Mechanics, this is Tom.",
          "speaker": "local party",
          "start_time": 0.5,
          "end_time": 2.5,
          "channel": "left",
          "id": 0
        },
        {
          "text": "Hi, my name is Kevin. A coworker recommended you. I need new tires for my 2021 Subaru Crosstrek.",
          "speaker": "remote party",
          "start_time": 2.8,
          "end_time": 9.0,
          "channel": "right",
          "id": 1
        },
        {
          "text": "What are you running now?",
          "speaker": "local party",
          "start_time": 9.2,
          "end_time": 10.5,
          "channel": "left",
          "id": 2
        },
        {
          "text": "I think they're 225/60R17.",
          "speaker": "remote party",
          "start_time": 10.8,
          "end_time": 12.5,
          "channel": "right",
          "id": 3
        },
        {
          "text": "Let me check what we have. We've got Michelin Defenders at $165 each or Continental TrueContact at $140 each. Both installed and balanced.",
          "speaker": "local party",
          "start_time": 12.8,
          "end_time": 21.0,
          "channel": "left",
          "id": 4
        },
        {
          "text": "I'll go with the Continentals. That's $560 plus tax for all four. When can I come in?",
          "speaker": "remote party",
          "start_time": 21.2,
          "end_time": 26.0,
          "channel": "right",
          "id": 5
        },
        {
          "text": "How about Wednesday at 11?",
          "speaker": "local party",
          "start_time": 26.2,
          "end_time": 28.0,
          "channel": "left",
          "id": 6
        },
        {
          "text": "Wednesday at 11 works. Thanks Tom.",
          "speaker": "remote party",
          "start_time": 28.2,
          "end_time": 30.5,
          "channel": "right",
          "id": 7
        },
        {
          "text": "See you then, Kevin.",
          "speaker": "local party",
          "start_time": 30.8,
          "end_time": 32.0,
          "channel": "left",
          "id": 8
        }
      ]
